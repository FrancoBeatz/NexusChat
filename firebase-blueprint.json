{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline", "typing"] },
        "lastSeen": { "type": "string" },
        "isAi": { "type": "boolean" }
      },
      "required": ["uid", "name"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat conversation between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string" },
        "topic": { "type": "string" }
      },
      "required": ["id", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A single chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "delivered", "read"] },
        "type": { "type": "string", "enum": ["text", "image", "system"] },
        "replyToId": { "type": "string" }
      },
      "required": ["id", "senderId", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/conversations/{convId}": {
      "schema": "Conversation",
      "description": "Chat conversations"
    },
    "/conversations/{convId}/messages/{msgId}": {
      "schema": "Message",
      "description": "Messages within a conversation"
    }
  }
}
